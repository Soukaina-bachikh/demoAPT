{
	"$4d": {
		"version": "1",
		"kind": "form"
	},
	"windowSizingX": "variable",
	"windowSizingY": "variable",
	"windowMinWidth": 900,
	"windowMinHeight": 620,
	"windowMaxWidth": 32767,
	"windowMaxHeight": 32767,
	"rightMargin": 20,
	"bottomMargin": 20,
	"events": [
		"onLoad",
		"onPageChange",
		"onValidate",
		"onClick",
		"onDoubleClick",
		"onOutsideCall",
		"onBeginDragOver",
		"onDragOver",
		"onDrop",
		"onAfterKeystroke",
		"onMenuSelect",
		"onPluginArea",
		"onAfterEdit",
		"onTimer",
		"onBoundVariableChange"
	],
	"windowTitle": "Appointment Manager",
	"destination": "detailScreen",
	"pages": [
		{
			"objects": {}
		},
		{
			"objects": {
				"title": {
					"type": "text",
					"text": "Appointment Manager",
					"top": 18,
					"left": 24,
					"width": 400,
					"height": 26,
					"fontSize": 20,
					"fontWeight": "bold",
					"stroke": "#12181f"
				},
				"subtitle": {
					"type": "text",
					"text": "Search, filter, and review appointments",
					"top": 46,
					"left": 24,
					"width": 500,
					"height": 16,
					"fontSize": 12,
					"stroke": "#5b6470"
				},
				"toolbarRule": {
					"type": "rectangle",
					"top": 74,
					"left": 0,
					"width": 900,
					"height": 1,
					"fill": "#e2e5ea",
					"stroke": "#e2e5ea",
					"strokeWidth": 0,
					"sizingX": "grow"
				},
				"searchField": {
					"type": "input",
					"top": 90,
					"left": 24,
					"width": 240,
					"height": 32,
					"dataSource": "Form.searchQuery",
					"placeholder": "Search by code or client name...",
					"fill": "#f5f6f8",
					"borderStyle": "none",
					"borderRadius": 8
				},
				"btnSearch": {
					"type": "button",
					"text": "Search",
