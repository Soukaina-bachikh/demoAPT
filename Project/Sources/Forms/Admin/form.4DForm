					"top": 138,
					"left": 24,
					"width": 500,
					"height": 460,
					"sizingX": "grow",
					"sizingY": "grow",
					"listboxType": "collection",
					"dataSource": "Form.appointments",
					"currentItemSource": "Form.currentAppointment",
					"selectionMode": "single",
					"stroke": "#e2e5ea",
